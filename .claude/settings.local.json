{
  "permissions": {
    "allow": [
      "Bash(zig version:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(zig build:*)",
      "Bash(grep -rn \"getStdOut\\\\|getStdErr\\\\|STDOUT\\\\|stdout\" /opt/homebrew/Cellar/zig/0.15.2/lib/zig/std/*.zig 2>/dev/null | head -30)",
      "Bash(./zig-out/bin/git-summary --help 2>&1)",
      "Bash(./zig-out/bin/git-summary . 2>&1)",
      "Bash(./zig-out/bin/git-summary --since \"1 year ago\" . 2>&1)",
      "Bash(./zig-out/bin/git-summary --since \"1 month ago\" ~/code 2>&1 | head -30)",
      "Bash(./zig-out/bin/git-summary --since \"1 year ago\" . 2>&1 | head -5)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
